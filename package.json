{
  "name": "ts-backend-boilerplate",
  "version": "1.0.0",
  "description": "Typescript Backend Boilerplate",
  "keywords": [
    "Typescript",
    "Boilerplate",
    "Backend",
    "Fastify",
    "Prisma",
    "ORM",
    "MinIO",
    "Scylladb",
    "Postgresql",
    "Valkey",
    "Elasticsearch"
  ],
  "homepage": "https://github.com/ashaffah/ts-backend-boilerplate#readme",
  "bugs": {
    "url": "https://github.com/ashaffah/ts-backend-boilerplate/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ashaffah/ts-backend-boilerplate.git"
  },
  "license": "Apache-2.0",
  "author": "Ashaffah",
  "main": "./dist/src/main.js",
  "module": "nodenext",
  "scripts": {
    "dev": "nodemon --exec tsx ./src/main.ts",
    "build:windows": "npx tsc -p ./prisma/tsconfig.json && powershell -File ./build-windows.ps1",
    "build:unix": "npx tsc -p ./prisma/tsconfig.json && rsync -av --include='*/' --exclude='*.ts' generated/ dist/generated/",
    "build:os": "node detect-os.ts && npm run build:windows || npm run build:unix",
    "build": "npm run build:os",
    "start": "node ./dist/src/main.js",
    "lint": "eslint ./src",
    "lint:fix": "eslint ./src --fix",
    "generate": "npx prisma generate",
    "migrate:dev": "npx prisma migrate dev",
    "migrate:deploy": "npx prisma migrate deploy",
    "migrate:reset": "npx prisma migrate reset",
    "db:seed": "npx prisma db seed",
    "helper": "sh -c '. ./.env 2>/dev/null; if [ \"$APP_ENV\" = \"production\" ]; then node ./dist/prisma/helper/main.js; else node --import=tsx prisma/helper/main.ts; fi'",
    "format": "npx prisma format",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/elasticsearch": "^4.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/middie": "^9.3.1",
    "@fastify/session": "^11.1.1",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@valkey/valkey-glide": "^2.3.1",
    "argon2": "^0.44.0",
    "arktype": "^2.2.0",
    "cassandra-driver": "^4.8.0",
    "dotenv": "^17.4.1",
    "eslint-config-next": "^16.2.3",
    "fastify": "^5.8.4",
    "minio": "^8.0.7",
    "paseto-ts": "^2.0.6",
    "pg": "^8.20.0",
    "pino-pretty": "^13.1.3",
    "redis": "^5.11.0",
    "ts-node": "^10.9.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "eslint": "^9.39.4",
    "nodemon": "^3.1.14",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
